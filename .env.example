# ────────────────────────────────────────────────
# Lovable Cloud (auto-managed — لا تعدّلها يدوياً)
# ────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ────────────────────────────────────────────────
# Directus (لما الـ backend جاهز نفعّله)
# ────────────────────────────────────────────────
# عنوان الـ Directus instance (UAE-hosted)
VITE_DIRECTUS_URL=https://directus.your-domain.ae

# تبديل: false = demo store (default), true = Directus
VITE_USE_DIRECTUS=false

# ────────────────────────────────────────────────
# سكربتات الـ bootstrap/seed فقط (مش للفرونت)
# لا تنشره ضمن .env العادي — استخدمه عبر CLI:
#   DIRECTUS_ADMIN_TOKEN=… bun run scripts/directus-bootstrap.ts
# ────────────────────────────────────────────────
DIRECTUS_URL=https://directus.your-domain.ae
DIRECTUS_ADMIN_TOKEN=
